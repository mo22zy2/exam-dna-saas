# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/examdna

# Redis connection string (used by RQ queue)
REDIS_URL=redis://localhost:6379/0

# Google OAuth 2.0 credentials
# Obtain from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT secret key for signing auth tokens
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=generate-a-random-secret-at-least-32-chars

# JWT token expiry in seconds (default: 7 days)
JWT_EXPIRY=604800

# R2 / S3-compatible storage (Cloudflare R2)
# Obtain from Cloudflare Dashboard → R2 → Account ID → API Tokens
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_REGION=auto
